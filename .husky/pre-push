#!/bin/sh

echo "🔍 Running pre-push checks..."

echo "📝 Linting..."
pnpm run lint
if [ $? -ne 0 ]; then
  echo "❌ Lint failed. Push aborted."
  exit 1
fi

echo "🔎 Type checking..."
pnpm run check-types
if [ $? -ne 0 ]; then
  echo "❌ Type check failed. Push aborted."
  exit 1
fi

echo "✅ All checks passed!"
